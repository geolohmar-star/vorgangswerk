# Vorgangswerk – Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an.

# ---------------------------------------------------------------------------
# Pflichtfelder
# ---------------------------------------------------------------------------

# Django Secret Key – zufälligen Wert generieren:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=bitte-aendern

# Datenbank
DB_PASSWORD=bitte-aendern

# Erlaubte Hostnamen (kommagetrennt)
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Optionale Dienste
# ---------------------------------------------------------------------------

# OnlyOffice Document Server (für DMS-Dokumentenbearbeitung im Browser)
ONLYOFFICE_URL=https://office.beispiel.de
ONLYOFFICE_INTERNAL_URL=http://host.docker.internal:8012
ONLYOFFICE_JWT_SECRET=

# Öffentliche Basis-URL dieser Instanz (für WOPI-Callbacks)
VORGANGSWERK_BASE_URL=http://localhost:8100
WOPI_BASE_URL=http://host.docker.internal:8100

# AES-256-GCM Verschlüsselung für sensible Dokumente
# Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VERSCHLUESSEL_KEY=

# ---------------------------------------------------------------------------
# E-Mail (SMTP ausgehend + IMAP eingehend)
# ---------------------------------------------------------------------------

EMAIL_HOST=smtp.beispiel.de
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@beispiel.de

IMAP_HOST=imap.beispiel.de
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# ---------------------------------------------------------------------------
# Digitale Signatur
# ---------------------------------------------------------------------------

# sign.me QES (Bundesdruckerei) – API-Key aus sign.me-Portal
SIGNME_API_KEY=

# ---------------------------------------------------------------------------
# KI-Portal (Formularanalyse via Claude)
# ---------------------------------------------------------------------------

# Anthropic Claude API-Key – https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Zahlungen (Stripe) – nur für Portal-Funktion nötig
# ---------------------------------------------------------------------------

STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# PDF-Werkzeuge (optional)
# ---------------------------------------------------------------------------

# URL zu einer Stirling-PDF / BentoPDF Instanz
BENTOPDF_URL=https://pdf.beispiel.de

# ---------------------------------------------------------------------------
# Entwicklung
# ---------------------------------------------------------------------------

DEBUG=False
