# Vorgangswerk – Umgebungsvariablen
# Kopieren nach .env und anpassen

SECRET_KEY=bitte-aendern-langer-zufaelliger-string
DEBUG=False

# Datenbank (PostgreSQL)
DATABASE_URL=postgresql://vorgangswerk:passwort@db:5432/vorgangswerk

# E-Mail (SMTP Ausgang)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# E-Mail (IMAP Eingang)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_POSTFACH=INBOX

# Collabora Online (optional)
COLLABORA_URL=

# Verschlüsselung für sensible Dokumente (AES-256-GCM)
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
VERSCHLUESSEL_KEY=

# sign.me QES (optional)
SIGNME_API_KEY=

# Erlaubte Hosts (kommagetrennt)
ALLOWED_HOSTS=localhost,127.0.0.1
